---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 5);
---

<div class="bg-base-100 p-6 rounded-2xl shadow-sm border border-border-base animate-fade-in">
    <h3 class="text-lg font-bold mb-4 dark:text-white flex items-center gap-2">
        <span class="icon-[tabler--flame] w-5 h-5 text-orange-500"></span>
        热门文章
    </h3>
    <div class="space-y-4">
        {posts.map((post, index) => (
            <a href={`/blog/${post.slug}`} class="flex items-start gap-3 group">
                <span class={`flex-shrink-0 w-6 h-6 flex items-center justify-center rounded text-xs font-bold transition-colors ${
                    index < 3 
                    ? 'bg-orange-100 dark:bg-orange-950/50 text-orange-500' 
                    : 'bg-gray-100 dark:bg-gray-800 text-gray-400'
                }`}>
                    {index + 1}
                </span>
                <div class="flex-1 min-w-0">
                    <h4 class="text-sm font-semibold text-text-base group-hover:text-primary transition-colors truncate">
                        {post.data.title}
                    </h4>
                    <time class="text-[10px] text-text-muted opacity-60">
                        {post.data.pubDate.toLocaleDateString('zh-CN')}
                    </time>
                </div>
            </a>
        ))}
    </div>
</div>
