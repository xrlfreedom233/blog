---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const searchList = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description || '',
  slug: post.slug,
  tags: post.data.tags || [],
}));
---

<div 
  id="search-root"
  x-data="{ searchOpen: false, query: '', results: [] }" 
  data-posts={JSON.stringify(searchList)}
  class="relative"
>
  <button 
    @click="searchOpen = true; $nextTick(() => $refs.searchInput.focus())"
    class="p-2 hover:text-primary transition-colors flex items-center"
    title="搜索"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <div 
    x-show="searchOpen" 
    x-cloak
    class="fixed inset-0 z-[100] flex items-start justify-center pt-24 px-4 bg-black/60 backdrop-blur-sm"
    @keydown.escape.window="searchOpen = false"
    style="display: none;"
  >
    <div 
      @click.away="searchOpen = false"
      class="w-full max-w-xl bg-base-100 rounded-2xl shadow-2xl overflow-hidden border border-border-base"
    >
      <div class="p-4 border-b border-border-base flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          x-ref="searchInput"
          type="text" 
          x-model="query" 
          id="search-input-field"
          placeholder="搜索文章标题、内容..." 
          class="w-full bg-transparent border-none focus:ring-0 text-lg text-text-base outline-none"
        />
      </div>

      <div class="max-h-[60vh] overflow-y-auto bg-base-100">
        <template x-if="results.length > 0">
          <div class="p-2 space-y-1">
            <template x-for="result in results" :key="result.slug">
              <a 
                :href="'/blog/' + result.slug"
                class="block p-4 rounded-xl hover:bg-base-200 transition-colors"
                @click="searchOpen = false"
              >
                <div class="font-bold text-text-base" x-text="result.title"></div>
                <div class="text-sm text-text-muted mt-1 line-clamp-1" x-text="result.description"></div>
              </a>
            </template>
          </div>
        </template>
        
        <template x-if="query.trim() && results.length === 0">
          <div class="p-12 text-center text-text-muted">暂无结果</div>
        </template>
      </div>
    </div>
  </div>
</div>

<script>
  import Fuse from 'fuse.js';

  function initSearch() {
    const root = document.getElementById('search-root');
    if (!root) return;

    const posts = JSON.parse(root.dataset.posts || '[]');
    const fuse = new Fuse(posts, {
      keys: ['title', 'description', 'tags'],
      threshold: 0.4
    });

    const input = document.getElementById('search-input-field');
    if (input) {
      input.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value;
        const results = query.trim() ? fuse.search(query).map(r => r.item).slice(0, 5) : [];
        
        if (window.Alpine) {
          const data = (window.Alpine as any).$data(root);
          data.results = results;
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', initSearch);
  document.addEventListener('astro:page-load', initSearch);
</script>
