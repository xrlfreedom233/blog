<div class="ripple-container backdrop-blur-[2px]">
  <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
  viewBox="0 24 150 40" preserveAspectRatio="none" shape-rendering="auto">
    <defs>
      <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
    </defs>
    <g class="parallax">
      <use xlink:href="#gentle-wave" x="48" y="0" class="wave-layer wave-1" />
      <use xlink:href="#gentle-wave" x="48" y="3" class="wave-layer wave-2" />
      <use xlink:href="#gentle-wave" x="48" y="5" class="wave-layer wave-3" />
      <use xlink:href="#gentle-wave" x="48" y="7" class="wave-layer wave-4" />
    </g>
  </svg>
</div>

<style>
.ripple-container {
  width: 100%;
  height: 80px;
  position: relative;
  overflow: hidden;
  margin-bottom: -3px; /* 增加覆盖范围，彻底消除缝隙 */
}

.waves {
  position: relative;
  width: 100%;
  height: 80px;
}

/* 动画部分 */
.parallax > use {
  animation: move-forever 25s cubic-bezier(.55,.5,.45,.5) infinite;
}
.parallax > use:nth-child(1) { animation-delay: -2s; animation-duration: 7s; }
.parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 10s; }
.parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 13s; }
.parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 20s; }

@keyframes move-forever {
  0% { transform: translate3d(-90px, 0, 0); }
  100% { transform: translate3d(85px, 0, 0); }
}

/* 极致透明颜色逻辑 */
/* 统一使用白色系，通过不透明度产生层次 */
.wave-1 { fill: rgba(255, 255, 255, 0.25); }
.wave-2 { fill: rgba(255, 255, 255, 0.2); }
.wave-3 { fill: rgba(255, 255, 255, 0.1); }
.wave-4 { fill: rgba(255, 255, 255, 0.4); }

/* 暗色模式下改用灰色系，防止过亮 */
:global(.dark) .wave-1 { fill: rgba(31, 41, 55, 0.25); }
:global(.dark) .wave-2 { fill: rgba(31, 41, 55, 0.2); }
:global(.dark) .wave-3 { fill: rgba(31, 41, 55, 0.1); }
:global(.dark) .wave-4 { fill: rgba(31, 41, 55, 0.4); }

@media (max-width: 768px) {
  .ripple-container, .waves {
    height: 50px;
  }
}
</style>
