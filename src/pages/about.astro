---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';

const skills = [
  { name: 'Vue / React', level: '90%' },
  { name: 'TypeScript', level: '85%' },
  { name: 'Astro', level: '95%' },
  { name: 'Tailwind CSS', level: '90%' },
  { name: 'Linux / Docker', level: '80%' },
];
---

<BaseLayout title="关于我 | freedom">
  <Header />
  <Hero title="关于我" subtitle="遇事不决，可问春风；此生辽阔，不负时光。" />
  
  <main class="container mx-auto px-4 py-20 max-w-4xl">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- 左侧：头像与简介 -->
      <div class="md:col-span-1 text-center">
        <img 
          src="https://tuchuang.xrlfreedom.top/2026/04/19d23f3d87c7ac449c8abbe36a4edbf0.webp" 
          class="w-32 h-32 rounded-full mx-auto mb-6 ring-4 ring-primary/20 shadow-xl object-cover" 
          alt="Avatar"
        />
        <h2 class="text-2xl font-bold dark:text-white mb-2">freedom</h2>
        <p class="text-gray-500 text-sm mb-6">全栈开发工程师 / 终身学习者</p>
        
        <div class="flex justify-center gap-4">
          <a href="#" class="text-gray-400 hover:text-primary transition-colors">GitHub</a>
          <a href="#" class="text-gray-400 hover:text-primary transition-colors">知乎</a>
        </div>
      </div>

      <!-- 右侧：详细介绍 -->
      <div class="md:col-span-2 space-y-12">
        <section>
          <h3 class="text-xl font-bold mb-4 dark:text-white flex items-center gap-2">
            <span class="w-1 h-6 bg-primary rounded-full"></span>
            自我介绍
          </h3>
          <p class="text-text-muted leading-relaxed">
            你好！我是 freedom。一名热爱折腾、追求极致体验的前端开发者。
            我喜欢用代码构建美观且实用的工具，通过文字记录技术成长与生活感悟。
            这个博客是我在数字世界的“自留地”，欢迎你常来逛逛。
          </p>
        </section>

        <section>
          <h3 class="text-xl font-bold mb-6 dark:text-white flex items-center gap-2">
            <span class="w-1 h-6 bg-primary rounded-full"></span>
            技能清单
          </h3>
          <div class="space-y-6">
            {skills.map(skill => (
              <div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="font-medium dark:text-gray-300">{skill.name}</span>
                  <span class="text-primary">{skill.level}</span>
                </div>
                <div class="w-full h-2 bg-base-200 rounded-full overflow-hidden">
                  <div class="h-full bg-primary transition-all duration-1000" style={`width: ${skill.level}`}></div>
                </div>
              </div>
            ))}
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
