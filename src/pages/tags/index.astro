---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Hero from '../../components/Hero.astro';

const allPosts = await getCollection('blog');
const tags = allPosts.reduce((acc, post) => {
  post.data.tags?.forEach(tag => {
    acc[tag] = (acc[tag] || 0) + 1;
  });
  return acc;
}, {} as Record<string, number>);

const tagList = Object.entries(tags).sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="全部标签 | Ideaflow">
  <Header />
  <Hero title="文章标签" subtitle={`全站共计 ${tagList.length} 个标签`} />
  
  <main class="container mx-auto px-4 py-20 max-w-4xl">
    <div class="flex flex-wrap justify-center gap-6">
      {tagList.map(([name, count], index) => (
        <a 
          href={`/tags/${name}`}
          class="group px-8 py-4 bg-base-100 rounded-2xl border border-border-base shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 animate-fade-in"
          style={`animation-delay: ${index * 50}ms`}
        >
          <div class="flex items-center gap-3">
            <span class="text-xl">#</span>
            <span class="text-lg font-bold text-text-base group-hover:text-primary transition-colors">{name}</span>
            <span class="text-xs text-text-muted bg-base-200 px-2 py-0.5 rounded-md">{count}</span>
          </div>
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
