---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import photos from '../data/photos.json';
---

<BaseLayout title="相册 | freedom">
	<Header />
	
	<main class="container mx-auto px-4 py-32">
		<h1 class="text-4xl font-bold mb-4 dark:text-white text-center">时光相册</h1>
		<p class="text-center text-gray-500 mb-16">每一张照片都是一次美好的记忆。</p>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" x-data="{ selectedImg: null }">
			{photos.map(photo => (
				<div 
					class="group relative aspect-square overflow-hidden rounded-2xl bg-gray-100 dark:bg-gray-800 cursor-pointer shadow-sm hover:shadow-xl transition-all duration-500"
					@click={`selectedImg = '${photo.url}'`}
				>
					<img 
						src={photo.url} 
						alt={photo.title}
						class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
					/>
					<div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-4">
						<span class="text-white font-bold text-lg mb-2 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
							{photo.title}
						</span>
						<span class="px-2 py-1 bg-white/20 backdrop-blur-md rounded text-xs text-white transform translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-75">
							{photo.category}
						</span>
					</div>
				</div>
			))}

			<!-- Lightbox Modal -->
			<div 
				x-show="selectedImg" 
				x-cloak
				class="fixed inset-0 z-[100] flex items-center justify-center bg-black/90 p-4"
				@click="selectedImg = null"
				x-transition:enter="transition ease-out duration-300"
				x-transition:enter-start="opacity-0"
				x-transition:enter-end="opacity-100"
			>
				<img :src="selectedImg" class="max-h-full max-w-full object-contain rounded-lg shadow-2xl" />
				<button class="absolute top-8 right-8 text-white text-4xl hover:scale-110 transition-transform">&times;</button>
			</div>
		</div>
	</main>

	<Footer />
</BaseLayout>
